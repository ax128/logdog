# =====================================================================
# LogWatch 环境变量配置
# 复制为 .env 后填入真实值
# =====================================================================

# ── Telegram Bot Token ───────────────────────────────────
# 可定义多个 token，在 logwatch.yaml 的 channel.bot_tokens 中引用
BOTTOKEN1=your-telegram-bot-token-1
# BOTTOKEN2=your-telegram-bot-token-2
# BOTTOKEN3=your-telegram-bot-token-3

# 可选：全局 Telegram token（优先级低于 channel 配置中的 bot_tokens）
# TELEGRAM_BOT_TOKEN=your-fallback-token

# ── Telegram Chat ID ─────────────────────────────────────
# 每个通道可以发到不同的群/人
CHAT_LOCAL=your-local-chat-id
# CHAT_PROD_API=your-prod-api-chat-id
# CHAT_PROD_OPS=your-prod-ops-chat-id
# CHAT_STAGING=your-staging-chat-id

# ── 企业微信 / WeCom Webhook ─────────────────────────────
# WECOM_WEBHOOK_PROD=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx
# WECOM_WEBHOOK_OPS=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=yyy

# ── 微信 / Weixin ────────────────────────────────────────
# WEIXIN_TARGET_PROD=your-weixin-target

# ── Web 鉴权 Token ───────────────────────────────────────
WEB_AUTH_TOKEN=your-auth-token
WEB_ADMIN_TOKEN=your-admin-token

# ── LLM / Agent ──────────────────────────────────────────
# 支持任何 OpenAI 兼容 API（官方/Azure/自建代理/agentop 等）
# 切换供应商只需改 BASE_URL 和 API_KEY

# --- 官方 OpenAI ---
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

# --- 自建/代理 (agentop, one-api, new-api 等) ---
# OPENAI_API_KEY=your-proxy-key
# OPENAI_BASE_URL=https://api.agentop.dev/v1/__gw__/t/8317
# LLM_MODEL=gpt-5.4

# --- Azure OpenAI ---
# OPENAI_API_KEY=your-azure-key
# OPENAI_BASE_URL=https://your-resource.openai.azure.com/openai/deployments/gpt-4o
# LLM_MODEL=gpt-4o

# ── 可选覆盖 ──────────────────────────────────────────────
# LOGWATCH_CONFIG=config/logwatch.yaml
# LOGWATCH_METRICS_DB_PATH=data/logwatch.db
