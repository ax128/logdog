# =====================================================================
# LogDog 环境变量配置
# 复制为 .env 后填入真实值
# =====================================================================

# ── Telegram Bot Token ───────────────────────────────────
# 可定义多个 token，在 logdog.yaml 的 channel.bot_tokens 中引用
BOTTOKEN1=your-telegram-bot-token-1
# BOTTOKEN2=your-telegram-bot-token-2
# BOTTOKEN3=your-telegram-bot-token-3

# 可选：全局 Telegram token（优先级低于 channel 配置中的 bot_tokens）
# TELEGRAM_BOT_TOKEN=your-fallback-token

# ── Telegram Chat ID ─────────────────────────────────────
# 每个通道可以发到不同的群/人
CHAT_LOCAL=your-local-chat-id
# CHAT_PROD_API=your-prod-api-chat-id
# CHAT_PROD_OPS=your-prod-ops-chat-id
# CHAT_STAGING=your-staging-chat-id

# ── 企业微信 / WeCom Webhook ─────────────────────────────
# WECOM_WEBHOOK_PROD=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx
# WECOM_WEBHOOK_OPS=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=yyy

# ── 微信 / Weixin ────────────────────────────────────────
# WEIXIN_TARGET_PROD=your-weixin-target

# ── Web 鉴权 Token ───────────────────────────────────────
WEB_AUTH_TOKEN=your-auth-token
WEB_ADMIN_TOKEN=your-admin-token

# ── LLM API Keys ─────────────────────────────────────────
# 多供应商模式: 每个供应商单独配置 key，在 logdog.yaml 的
# llm.providers 中用 ${VAR} 引用
AGENTOP_API_KEY=your-agentop-api-key
# OPENAI_API_KEY=sk-xxx
# XAI_API_KEY=your-xai-key
# AZURE_OPENAI_KEY=your-azure-key
# ANTHROPIC_KEY=your-anthropic-key

# ── 单供应商模式 (简易) ──────────────────────────────────
# 如果只用一个供应商，可直接设这两个变量，不需要在 YAML 里配 providers
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

# ── 生产主机 SSH 连接 ──────────────────────────────────────
# 对应 logdog.yaml 中 hosts[name=prod] 的连接信息
PROD_HOST=your-prod-server-ip-or-hostname
PROD_PORT=22
PROD_USER=root
PROD_SSH_KEY=/root/.ssh/id_ed25519

# ── 可选覆盖 ──────────────────────────────────────────────
# LOGDOG_CONFIG=config/logdog.yaml
# LOGDOG_METRICS_DB_PATH=data/logdog.db
