# =====================================================================
# LogWatch 配置文件
# 复制为 config/logwatch.yaml 后按需修改
#
# 核心概念:
#   channels  - 定义消息通道（Telegram/WeCom/Weixin 等）
#   routing   - 定义路由规则（按服务器/容器/告警类别分发到不同通道）
#   hosts     - 定义被监控的服务器及其允许的通道白名单
#
# 消息路由流程:
#   告警触发 → routing.rules 按 priority 从高到低匹配
#     → 命中规则 → 发到规则指定的 channels
#     → 未命中   → 发到 routing.default_channels
#     → default 也为空 → 回退到该 host 白名单中的全部通道
# =====================================================================


# ── 指标采样 ──────────────────────────────────────────────
metrics:
  sample_interval_seconds: 30
  host_system:
    enabled: false
    sample_interval_seconds: 30
    collect_load: true
    collect_network: true
    security:
      enabled: false
      push_on_issue: true
    report:
      include_in_schedule: true
      warn_thresholds:
        cpu_percent: 85
        mem_used_percent: 90
        disk_used_percent: 90


# ── 存储 ──────────────────────────────────────────────────
storage:
  db_path: data/logwatch.db
  sqlite:
    journal_mode: wal
    synchronous: normal
    busy_timeout_ms: 5000
  retention:
    cleanup_interval_seconds: 86400
    alerts_days: 30
    audit_days: 30
    send_failed_days: 14
    metrics_days: 7
    host_metrics_days: 7
    storm_days: 14


# ── Docker 连接池 ─────────────────────────────────────────
docker:
  pool:
    max_clients: 8
    max_idle_seconds: 60


# ── 调度器 ────────────────────────────────────────────────
scheduler:
  max_instances: 1
  coalesce: true
  misfire_grace_time: 30


# =====================================================================
# 通知系统
# =====================================================================
notify:

  # ──────────────────────────────────────────────────────
  # 通道定义
  #
  # 每个通道是一个独立的消息投递目标。
  # 通道名自由命名，在 routing.rules 和 hosts[].notify.channels 中引用。
  #
  # 支持的类型: telegram / wechat / weixin / wecom
  #
  # Telegram 通道参数:
  #   bot_tokens    - Bot Token 列表（支持环境变量 ${VAR}）
  #   chat_ids      - 目标 Chat ID 列表（不填则用 auto_chat_id）
  #   auto_chat_id  - true 时自动发现最近对话的 chat（适合单人调试）
  #   message_mode  - text / txt / md / doc
  #
  # WeCom 通道参数:
  #   targets       - Webhook URL 列表
  #   message_mode  - text / md
  #
  # Weixin 通道参数:
  #   targets       - 目标列表
  #   message_mode  - text / md
  # ──────────────────────────────────────────────────────
  channels:

    # ── 示例: 本地开发用 Telegram ──
    local-tel:
      type: telegram
      enabled: true
      bot_tokens: ["${BOTTOKEN1}"]
      chat_ids: ["${CHAT_LOCAL}"]
      message_mode: md

    # ── 示例: 生产 API 告警专用 Telegram 群 ──
    # prod-api-tel:
    #   type: telegram
    #   enabled: true
    #   bot_tokens: ["${BOTTOKEN1}"]
    #   chat_ids: ["${CHAT_PROD_API}"]
    #   message_mode: md

    # ── 示例: 生产运维 Telegram 群 ──
    # prod-ops-tel:
    #   type: telegram
    #   enabled: true
    #   bot_tokens: ["${BOTTOKEN1}"]
    #   chat_ids: ["${CHAT_PROD_OPS}"]
    #   message_mode: md

    # ── 示例: 测试环境 Telegram (用不同的 bot) ──
    # staging-tel:
    #   type: telegram
    #   enabled: true
    #   bot_tokens: ["${BOTTOKEN2}"]
    #   chat_ids: ["${CHAT_STAGING}"]
    #   message_mode: text

    # ── 示例: 企业微信告警通道 ──
    # prod-wecom:
    #   type: wecom
    #   enabled: true
    #   targets: ["${WECOM_WEBHOOK_PROD}"]
    #   message_mode: md

    # ── 示例: 企业微信运维通道 ──
    # ops-wecom:
    #   type: wecom
    #   enabled: true
    #   targets: ["${WECOM_WEBHOOK_OPS}"]
    #   message_mode: md


  # ──────────────────────────────────────────────────────
  # 路由规则
  #
  # 告警触发后按 priority 从高到低逐条匹配:
  #   match.hosts       - 服务器名通配 (fnmatch)，如 ["prod-*"]
  #   match.containers  - 容器名/ID通配，如 ["api", "gateway-*"]
  #   match.categories  - 告警类别，如 ["ERROR", "OOM", "BUSINESS"]
  #
  # 三个条件取交集: 全部满足才算命中。
  # 省略某条件 = 不限制该维度。
  #
  # 命中后发到 deliver.channels 指定的通道。
  # 全部规则未命中 → 使用 default_channels。
  # default_channels 也为空 → 回退到 host 白名单的全部通道。
  #
  # 建议:
  #   - 精确规则用高 priority (100+)
  #   - 每台服务器配一条兜底规则 (priority: 1)
  # ──────────────────────────────────────────────────────
  routing:
    default_channels: [local-tel]

    rules: []

    # ── 示例: 多服务器多容器精细路由 ──
    #
    # rules:
    #   # 生产 API 容器的严重告警 → API 专属群
    #   - name: prod-api-critical
    #     priority: 100
    #     match:
    #       hosts: ["prod"]
    #       containers: ["api", "api-*", "gateway"]
    #       categories: ["ERROR", "OOM"]
    #     deliver:
    #       channels: ["prod-api-tel"]
    #       message_mode: md
    #
    #   # 生产数据库容器 → 企业微信运维
    #   - name: prod-db
    #     priority: 100
    #     match:
    #       hosts: ["prod"]
    #       containers: ["mysql", "redis", "postgres"]
    #     deliver:
    #       channels: ["ops-wecom"]
    #
    #   # 生产其他容器 → 运维 Telegram (兜底)
    #   - name: prod-fallback
    #     priority: 1
    #     match:
    #       hosts: ["prod"]
    #     deliver:
    #       channels: ["prod-ops-tel"]
    #
    #   # 测试环境全部 → 测试群
    #   - name: staging-all
    #     priority: 1
    #     match:
    #       hosts: ["staging"]
    #     deliver:
    #       channels: ["staging-tel"]
    #
    #   # OOM 全局加报企业微信 (不限服务器)
    #   - name: global-oom
    #     priority: 200
    #     match:
    #       categories: ["OOM"]
    #     deliver:
    #       channels: ["prod-wecom"]


# ── LLM / Agent ──────────────────────────────────────────
llm:
  enabled: true
  # model: "openai:${LLM_MODEL}"

agent:
  authorized_users:
    telegram: []
    # 填入你的 Telegram User ID，允许通过 Bot 交互
    # 获取方式: 给 @userinfobot 发消息，拿到你的 id
    # telegram: ["123456789"]


# ── 默认值 (所有 host 继承) ───────────────────────────────
defaults:
  schedules_mode: append
  schedules:
    - name: default
      interval_seconds: 300
  containers:
    exclude:
      - logwatch
  watch:
    queue_maxsize: 1024
    worker_count: 2
    drop_when_full: true


# =====================================================================
# 被监控的服务器
#
# 每台服务器可配置:
#   url             - Docker 连接地址
#   ssh_key         - SSH 密钥路径 (ssh:// 连接时需要)
#   prompt_template - 告警分析提示词模板 (服务器默认)
#   output_template - 告警输出格式模板 (服务器默认)
#   notify.channels - 该服务器允许使用的通道白名单
#   containers      - 容器筛选 + 容器级自定义配置
#
# ── 可用的模板 ──
#   prompt_template: default_alert / default_daily / default_hourly /
#                    default_heartbeat / default_interval
#                    (或自定义: 放在 templates/prompts/ 目录下)
#
#   output_template: standard / brief / detailed / ops_friendly /
#                    business / heartbeat
#                    (或自定义: 放在 templates/output/ 目录下)
# =====================================================================
hosts:
  # ── 本地开发 ──
  - name: local
    url: unix:///var/run/docker.sock
    notify:
      channels: [local-tel]

  # ── 生产服务器 (完整示例) ──
  # - name: prod
  #   url: ssh://root@10.0.1.1:22
  #   ssh_key: /root/.ssh/id_ed25519
  #   prompt_template: default_alert     # 该服务器的默认提示词
  #   output_template: ops_friendly      # 该服务器的默认输出格式
  #   notify:
  #     channels: [prod-api-tel, prod-ops-tel, ops-wecom]
  #
  #   containers:
  #     # 只监听这些容器 (不配 include = 监听全部)
  #     include: [api, api-*, worker-*, nginx, redis]
  #     # 排除这些容器
  #     exclude: [logwatch, tmp-*]
  #
  #     # ── 容器级自定义 ──
  #     # 支持精确名称或通配符 (fnmatch)
  #     # 每个容器可独立设置提示词、输出格式、告警规则
  #     overrides:
  #       api:
  #         prompt_template: api_alert      # api 用专属提示词
  #         output_template: detailed       # api 用详细输出
  #         rules:
  #           alert_keywords: [error, fatal, "5xx", timeout]
  #           ignore: ["health.?check", "GET /ping"]
  #
  #       "worker-*":                       # 所有 worker 容器
  #         prompt_template: worker_alert
  #         output_template: brief
  #         rules:
  #           alert_keywords: [error, fatal, oom]
  #           ignore: ["retry succeeded"]
  #
  #       redis:
  #         rules:
  #           alert_keywords: [error, oom, "maxmemory"]
  #           ignore: ["Saving RDB", "Background saving"]

  # ── 测试环境 ──
  # - name: staging
  #   url: ssh://deploy@10.0.2.1:22
  #   ssh_key: /root/.ssh/id_ed25519
  #   output_template: brief             # 测试环境用简短格式
  #   notify:
  #     channels: [staging-tel]
  #   containers:
  #     exclude: [logwatch]


# =====================================================================
# 快速上手（最简配置）
#
# 1. 复制本文件为 config/logwatch.yaml
# 2. 复制 .env.example 为 .env
# 3. 在 .env 中填入:
#      BOTTOKEN1=你的BotToken
#      CHAT_LOCAL=你的ChatID
# 4. 启动: docker compose up -d
#
# 所有服务器的告警都会发到 local-tel 这个通道。
#
# 需要分流时:
#   channels  - 添加通道定义
#   rules     - 添加路由规则 (按服务器/容器/类别)
#   hosts     - 配置通道白名单 + 容器筛选 + 容器级覆盖
# =====================================================================
